ode","source":["import numpy as np\n","import pandas as pd\n","import vectorbt as vbt\n","\n","\n","def build_parent_lag_map(te_result: dict) -> pd.DataFrame:\n","    edges = te_result[\"edges\"].copy()\n","    return edges[[\"parent\", \"child\", \"lag\", \"te\"]].set_index(\"child\").sort_index()\n","\n","\n","def simulate_te_tree_strategy(\n","    te_result: dict,\n","    returns_test: pd.DataFrame,\n","    price_test: pd.DataFrame | None = None,\n","    trade_root: bool = False,\n","    gross_exposure: float = 1.0,\n","    weighting: str = \"equal\",   # \"equal\" or \"te\"\n","    fees: float = 0.0,\n","    slippage: float = 0.0,\n","    init_cash: float = 100_000.0,\n","    freq: str | None = None,\n","):\n","    \"\"\"\n","    Simulate test-period trades from a frozen TE arborescence.\n","\n","    Rules:\n","    - Each child follows sign(parent_return.shift(lag)).\n","    - Orders are sent only when that sign changes.\n","    - Orders execute one bar later via fshift(1), so no same-bar leakage.\n","    - Root is excluded by default.\n","    \"\"\"\n","\n","    returns_test = returns_test.sort_index().copy()\n","    tickers = list(returns_test.columns)\n","\n","    if price_test is None:\n","        # Build synthetic price from returns if only returns are available\n","        price_test = (1.0 + returns_test.fillna(0.0)).cumprod()\n","    else:\n","        price_test = price_test.loc[returns_test.index, tickers].copy()\n","\n","    root = te_result[\"root\"]\n","    parent_lag = build_parent_lag_map(te_result)\n","\n","    tradable = [c for c in tickers if c in parent_lag.index]\n","    if trade_root and root in tickers:\n","        tradable = [root] + tradable\n","\n","    if len(tradable) == 0:\n","        raise ValueError(\"No tradable child assets found in test data.\")\n","\n","    # Per-asset predictive sign from parent and lag\n","    signal = pd.DataFrame(index=returns_test.index, columns=tickers, dtype=float)\n","\n","    for child, row in parent_lag.iterrows():\n","        parent = row[\"parent\"]\n","        lag = int(row[\"lag\"]) if pd.notna(row[\"lag\"]) else 1\n","\n","        if child not in returns_test.columns or parent not in returns_test.columns:\n","            continue\n","\n","        # Predict child direction using lagged parent direction\n","        signal[child] = np.sign(returns_test[parent].shift(lag))\n","\n","    if trade_root and root in signal.columns:\n","        # Optional: trade root on its own lag-1 momentum\n","        signal[root] = np.sign(returns_test[root].shift(1))\n","\n","    # Keep only tradable columns\n","    signal = signal[tradable]\n","\n","    # Neutralize zeros/NaNs\n","    signal = signal.where(signal != 0.0, np.nan)\n","\n","    # Rebalance only when predicted direction changes\n","    rebalance_mask = signal.ne(signal.shift(1))\n","\n","    # One-bar execution delay\n","    target_signal = signal.shift(1)\n","    rebalance_mask = rebalance_mask.shift(1).fillna(False)\n","\n","    # Weights only on rebalance bars; NaN otherwise => no order\n","    if weighting == \"equal\":\n","        n_assets = len(tradable)\n","        base_weight = gross_exposure / n_assets\n","        target_weights = np.sign(target_signal) * base_weight\n","\n","    elif weighting == \"te\":\n","        edges = te_result[\"edges\"].copy()\n","        edge_te = edges.set_index(\"child\")[\"te\"].reindex(tradable).fillna(0.0)\n","        if edge_te.sum() == 0:\n","            raise ValueError(\"TE weights sum to zero.\")\n","        edge_te = gross_exposure * edge_te / edge_te.sum()\n","        target_weights = np.sign(target_signal).mul(edge_te, axis=1)\n","\n","    else:\n","        raise ValueError(\"weighting must be 'equal' or 'te'\")\n","\n","    orders = target_weights.where(rebalance_mask, np.nan)\n","\n","    # Optional: flatten everything when signal disappears\n","    # If you want exact flatting on NaN/0 after shift:\n","    prev_sig = np.sign(target_signal.shift(1))\n","    curr_sig = np.sign(target_signal)\n","    went_flat = prev_sig.notna() & curr_sig.isna()\n","    orders = orders.mask(went_flat, 0.0)\n","\n","    pf = vbt.Portfolio.from_orders(\n","        close=price_test[tradable],\n","        size=orders,\n","        size_type=\"targetpercent\",\n","        direction=\"both\",\n","        group_by=True,\n","        cash_sharing=True,\n","        call_seq=\"auto\",\n","        init_cash=init_cash,\n","        fees=fees,\n","        slippage=slippage,\n","        freq=freq,\n","    )\n","\n","    return {\n","        \"portfolio\": pf,\n","        \"signal\": signal,\n","        \"target_signal\": target_signal,\n","        \"rebalance_mask\": rebalance_mask,\n","        \"orders\": orders,\n","        \"tradable\": tradable,\n","        \"parent_lag\": parent_lag,\n","    }\n","\n","train_end = \"2024-01-01\"\n","\n","result = build_te_lag_arborescence(\n","    returns_df=df_returns.loc[:train_end],\n","    calculate_te_func=calculate_transfer_entropy_with_edge_lag,\n","    #calculate_te_func=calculate_transfer_entropy,\n","    max_lag=10,\n","    min_obs=500,\n","    edge_threshold=0.0,\n","    root_mode=\"auto\",\n",")\n","\n","idx = df_returns.index\n","train_end_ts = pd.Timestamp(train_end)\n","\n","if getattr(idx, \"tz\", None) is not None:\n","    # index is tz-aware -> localize or convert split timestamp\n","    if train_end_ts.tzinfo is None:\n","        train_end_ts = train_end_ts.tz_localize(idx.tz)\n","    else:\n","        train_end_ts = train_end_ts.tz_convert(idx.tz)\n","else:\n","    # index is tz-naive -> strip tz from split timestamp if needed\n","    if train_end_ts.tzinfo is not None:\n","        train_end_ts = train_end_ts.tz_localize(None)\n","\n","returns_test = df_returns.loc[train_end_ts + pd.Timedelta(minutes=2):]\n","\n","bt = simulate_te_tree_strategy(\n","    te_result=result,\n","    returns_test=returns_test,\n","    price_test=close.loc[train_end_ts + pd.Timedelta(minutes=1):],         # synthetic price from returns\n","    trade_root=False,\n","    gross_exposure=1.0,\n","    weighting=\"te\",       # or \"te\"\n","    fees=0.001,\n","    slippage=0.0001,\n","    init_cash=100_000,\n","    freq=\"1d\",\n",")\n","\n","pf = bt[\"portfolio\"]\n","\n","print(pf.stats())\n","print(pf.orders.records_readable.head(20))\n","print(pf.positions.records_readable.head(20))\n","pf.value().plot()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"collapsed":true,"id":"hTG4GnFPIM1S","executionInfo":{"status":"ok","timestamp":1773123564723,"user_tz":420,"elapsed":283317,"user":{"displayName":"Klepto Mikey","userId":"16754173383394045540"}},"outputId":"fc061e51-b912-4150-e892-147dc7aabaa2"},"execution_count":92,"outputs":[{"output_type":"stream","name":"stdout","text":["Start                               2024-01-02 00:00:00\n","End                                 2026-03-10 00:00:00\n","Period                                799 days 00:00:00\n","Start Value                                    100000.0\n","End Value                                  67334.733456\n","Total Return [%]                             -32.665267\n","Benchmark Return [%]                         110.667312\n","Max Gross Exposure [%]                       103.469889\n","Total Fees Paid                            33008.061268\n","Max Drawdown [%]                              35.284004\n","Max Drawdown Duration                 743 days 00:00:00\n","Total Trades                                       2521\n","Total Closed Trades                                2520\n","Total Open Trades                                     1\n","Open Trade PnL                                      0.0\n","Win Rate [%]                                  43.571429\n","Best Trade [%]                               118.047993\n","Worst Trade [%]                              -32.925893\n","Avg Winning Trade [%]                          2.587449\n","Avg Losing Trade [%]                          -2.277765\n","Avg Winning 