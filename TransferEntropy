p.asarray(X)\n","    Y = np.asarray(Y)\n","\n","    if X.ndim == 1:\n","        X = X.reshape(-1, 1)\n","    if Y.ndim == 1:\n","        Y = Y.reshape(-1, 1)\n","\n","    if X.shape[0] != Y.shape[0]:\n","        raise ValueError(\"X and Y must have same number of samples\")\n","\n","    def make_est():\n","        return CopulaEntropyEstimator(\n","            degree=degree,\n","            max_num_mc=max_num_mc,\n","            max_num_mc_adapt=max_num_mc_adapt,\n","            alpha_reg=alpha_reg,\n","            random_state=random_state,\n","            feature_mode=feature_mode,\n","            boundary_features=boundary_features,\n","            n_spline_degree=n_spline_degree,\n","            n_spline_basis=n_spline_basis,\n","            cross=cross,\n","            pairwise=pairwise\n","        )\n","\n","    # Marginals\n","    h_x = 0.0 if X.shape[1] == 1 else float(make_est().compute(X)[0])\n","    #h_y = 0.0 if Y.shape[1] == 1 else float(make_est().compute(Y)[0])\n","\n","    # Joint (must use the same transformed reps for the decomposition to make sense)\n","    XY = np.hstack([X, Y])\n","    h_xy = float(make_est().compute(XY)[0])\n","\n","    return float(h_x - h_xy)"]},{"cell_type":"code","source":["import numpy as np\n","\n","def calculate_transfer_entropy(X, Y, max_lag=10, return_lag=False):\n","    \"\"\"\n","    Calculates Transfer Entropy from Y to X: TE(Y -> X)\n","\n","    Parameters\n","    ----------\n","    X, Y : array-like\n","        Time series.\n","    max_lag : int\n","        Max lag to search for the target's embedding lag.\n","    return_lag : bool\n","        If True, return (te, optimal_lag).\n","\n","    Returns\n","    -------\n","    te : float\n","        Transfer entropy TE(Y -> X)\n","    optimal_lag : int, optional\n","        Chosen lag used in the calculation.\n","    \"\"\"\n","    X = np.asarray(X).flatten()\n","    Y = np.asarray(Y).flatten()\n","    n_samples = len(X)\n","\n","    mi_kwargs = {}\n","\n","    if n_samples <= max_lag:\n","        raise ValueError(\"max_lag must be smaller than the number of samples.\")\n","\n","    ami_values = []\n","\n","    for l in range(1, max_lag + 1):\n","        x_curr_tmp = X[l:].reshape(-1, 1)\n","        x_past_tmp = X[:-l].reshape(-1, 1)\n","        mi = estimate_mi_from_ce(x_curr_tmp, x_past_tmp, **mi_kwargs)\n","        ami_values.append(mi)\n","\n","    optimal_lag = 1\n","    for i in range(1, len(ami_values) - 1):\n","        if ami_values[i] < ami_values[i - 1] and ami_values[i] < ami_values[i + 1]:\n","            optimal_lag = i + 1\n","            break\n","    else:\n","        optimal_lag = int(np.argmin(ami_values) + 1)\n","\n","    x_curr = X[optimal_lag:].reshape(-1, 1)\n","    x_past = X[:-optimal_lag].reshape(-1, 1)\n","    y_past = Y[:-optimal_lag].reshape(-1, 1)\n","\n","    joint_past = np.hstack([x_past, y_past])\n","\n","    mi_full = estimate_mi_from_ce(x_curr, joint_past, **mi_kwargs)\n","    mi_self = estimate_mi_from_ce(x_curr, x_past, **mi_kwargs)\n","\n","    te = mi_full - mi_self\n","    te = max(float(te), 0.0)\n","\n","    if return_lag:\n","        return te, optimal_lag\n","    return te\n","\n","\n","import numpy as np\n","\n","\n","def calculate_transfer_entropy_with_edge_lag(X, Y, max_lag=10, return_lag=False):\n","    \"\"\"\n","    Calculates TE(Y -> X), choosing the lag that maximizes TE over 1..max_lag.\n","\n","    Parameters\n","    ----------\n","    X, Y : array-like\n","        Time series.\n","    max_lag : int\n","        Maximum lag to test.\n","    return_lag : bool\n","        If True, return (best_te, best_lag).\n","\n","    Returns\n","    -------\n","    best_te : float\n","        Best TE(Y -> X)\n","    best_lag : int, optional\n","        Lag that maximized TE.\n","    \"\"\"\n","    X = np.asarray(X).flatten()\n","    Y = np.asarray(Y).flatten()\n","    n_samples = len(X)\n","\n","    mi_kwargs = {}\n","\n","    if n_samples <= max_lag:\n","        raise ValueError(\"max_lag must be smaller than the number of samples.\")\n","\n","    best_te = -np.inf\n","    best_lag = 1\n","\n","    for lag in range(1, max_lag + 1):\n","        x_curr = X[lag:].reshape(-1, 1)\n","        x_past = X[:-lag].reshape(-1, 1)\n","        y_past = Y[:-lag].reshape(-1, 1)\n","\n","        joint_past = np.hstack([x_past, y_past])\n","\n","        mi_full = estimate_mi_from_ce(x_curr, joint_past, **mi_kwargs)\n","        mi_self = estimate_mi_from_ce(x_curr, x_past, **mi_kwargs)\n","\n","        te = float(mi_full - mi_self)\n","\n","        if te > best_te:\n","            best_te = te\n","            best_lag = lag\n","\n","    best_te = max(best_te, 0.0)\n","\n","    if return_lag:\n","        return best_te, best_lag\n","    return best_te"],"metadata":{"id":"9q27Mv7dBCJK","executionInfo":{"status":"ok","timestamp":1773117553383,"user_tz":420,"elapsed":25,"user":{"displayName":"Klepto Mikey","userId":"16754173383394045540"}}},"execution_count":15,"outputs":[]},{"cell_type":"code","source":["import numpy as np\n","import pandas as pd\n","from scipy.cluster.hierarchy import linkage, leaves_list\n","from scipy.spatial.distance import squareform\n","\n","def build_hierarchical_te_field(\n","    returns_df: pd.DataFrame,\n","    calculate_transfer_entropy,\n","    te_kwargs: dict | None = None,\n","    corr_method: str = \"spearman\",\n","    linkage_method: str = \"average\",\n","    corr_shrinkage: float = 0.0,\n","    min_obs: int = 50,\n","    zero_negative_te: bool = True,\n","    symmetrize_for_tree: str = \"corr\",   # \"corr\" or \"te\"\n","    smooth_iters: int = 2,\n","    smooth_alpha: float = 0.5,\n","):\n","    \"\"\"\n","    Build a hierarchically-regularized directed information-flow field from asset returns.\n","\n","    Bottom-line implementation:\n","      1. build a hierarchy from a stable symmetric dependence measure,\n","      2. estimate a directed TE matrix on returns,\n","      3. aggregate directional flow across the hierarchy,\n","      4. infer per-asset source/sink scores,\n","      5. smooth those scores using the tree neighborhood.\n","\n","    Parameters\n","    ----------\n","    returns_df : pd.DataFrame\n","        Index must be datetime-like, columns are tickers, values are returns.\n","    calculate_transfer_entropy : callable\n","        Function with signature like:\n","            calculate_transfer_entropy(x, y, **kwargs) -> float\n","        Interpreted as TE(x -> y).\n","    te_kwargs : dict, optional\n","        Extra kwargs passed into calculate_transfer_entropy.\n","    corr_method : str\n","        Correlation method for hierarchy construction when symmetrize_for_tree=\"corr\".\n","    linkage_method : str\n","        Linkage method passed to scipy.cluster.hierarchy.linkage.\n","    corr_shrinkage : float\n","        Optional shrinkage toward identity for the correlation matrix, in [0, 1].\n","    min_obs : int\n","        Minimum overlapping observations required for pairwise TE / correlation use.\n","    zero_negative_te : bool\n","        If True, negative TE estimates are clipped to 0.\n","    symmetrize_for_tree : str\n","        \"corr\" -> build hierarchy from correlation distance\n","        \"te\"   -> build hierarchy from symmetrized TE distance\n","    smooth_iters : int\n","        Number of smoothing passes over leaf neighbors in dendrogram order.\n","    smooth_alpha : float\n","        Strength of smoothing in [0, 1]. 0=no smoothing, 1=max local averaging.\n","\n","    Returns\n","    -------\n","    result : dict with keys\n","        te_matrix              : directed TE matrix (DataFrame)\n","        symmetric_similarity   : symmetric matrix used for hierarchy (DataFrame)\n","        distance_matrix        : symmetric distance matrix used for linkage (DataFrame)\n","        linkage_matrix         : scipy linkage matrix\n","        leaf_order             : list of tickers in dendrogram leaf order\n","        raw_source_score       : outflow - inflow per asset (Series)\n","        smoothed_source_score  : hierarchically smoothed source score (Series)\n","        cluster_flow           : DataFrame of cluster-to-cluster net flow by top split\n","        top_split_labels       : Series mapping ticker -> top-level cluster label (0/1)\n","        metadata               : dict of settings\n","    \"\"\"\n","    te_kwargs = te_kwargs or {}\n","\n","    df = returns_df.copy().sort_index()\n","    df = df.replace([np.inf, -np.inf], np.nan)\n","\n","    # Drop columns with too little data\n","    valid_cols = [c for c in df.columns if df[c].notna().sum() >= min_obs]\n","    df = df[valid_cols]\n","    tickers = list(df.columns)\n","    n = len(tickers)\n","\n","    if n < 2:\n","        raise ValueError(\"Need at least 2 sufficiently populated series.\")\n","\n","    # ------------------------------------------------------------------\n","    # 1) Build a stable symmetric dependence measure for the tree\n","    # ------------------------------------------------------------------\n","    if symmetrize_for_tree == \"corr\":\n","        corr = df.corr(method=corr_method)\n","\n","        if corr_shrinkage > 0:\n","            I = pd.DataFrame(np.eye(n), index=tickers, columns=tickers)\n","            corr = (1 - corr_shrinkage) * corr + corr_shrinkage * I\n","\n","        corr = corr.fillna(0.0).clip(-1.0, 1.0)\n","\n","        # HRP-style distance\n","        dist = np.sqrt(0.5 * (1.0 - corr))\n","        np.fill_diagonal(dist.values, 0.0)\n","\n","        symmetric_similarity = corr.copy()\n","\n","    elif symmetrize_for_tree == \"te\":\n","        # First estimate TE matrix, then use symmetrized TE for the tree\n","        te_mat = _compute_te_matrix(\n","            df,\n","            calculate_transfer_entropy=calculate_transfer_entropy,\n","            te_kwargs=te_kwargs,\n","            min_obs=min_obs,\n","            zero_negative_te=zero_negative_te,\n","        )\n","        symmetric_similarity = 0.5 * (te_mat + te_mat.T)\n","\n","        sim = symmetric_similarity.values.copy()\n","        sim = np.nan_to_num(sim, nan=0.0, posinf=0.0, neginf=0.0)\n","\n","        # Convert similarity to distance\n","        # Larger TE similarity -> smaller distance\n","        eps = 1e-12\n","        max_sim = sim.max()\n","        if max_sim <= eps:\n","            dist = np.ones_like(sim) - np.eye(n)\n","        else:\n","            dist = 1.0 - (sim / (max_sim + eps))\n","            np.fill_diagonal(dist, 0.0)\n","\n","        dist = pd.DataFrame(dist, index=tickers, columns=tickers)\n","\n","    else:\n","        raise ValueError(\"symmetrize_for_tree must be 'corr' or 'te'\")\n","\n","    # Ensure valid condensed distance for clustering\n","    dist_values = dist.values.astype(float)\n","    dist_values = 0.5 * (dist_values + dist_values.T)\n","    np.fill_diagonal(dist_values, 0.0)\n","    dist_values = np.clip(dist_values, 0.0, None)\n","\n","    condensed = squareform(dist_values, checks=False)\n","    Z = linkage(condensed, method=linkage_method)\n","    leaf_idx = leaves_list(Z)\n","    leaf_order = [tickers[i] for i in leaf_idx]\n","\n","    # ------------------------------------------------------------------\n","    # 2) Estimate directed TE matrix (if not already done above)\n","    # ------------------------------------------------------------------\n","    if symmetrize_for_tree != \"te\":\n","        te_mat = _compute_te_matrix(\n","            df,\n","            calculate_transfer_entropy=calculate_transfer_entropy,\n","            te_kwargs=te_kwargs,\n","            min_obs=min_obs,\n","            zero_negative_te=zero_negative_te,\n","        )\n","\n","    # ------------------------------------------------------------------\n","    # 3) Infer raw source/sink scores\n","    #    source score = total outflow - total inflow\n","    # ------------------------------------------------------------------\n","    outflow = te_mat.sum(axis=1)\n","    inflow = te_mat.sum(axis=0)\n","    raw_source_score = outflow - inflow\n","\n","    # ------------------------------------------------------------------\n","    # 4) Smooth source scores using the tree neighborhood (leaf order)\n","    #    Simple but effective local regularization along dendrogram leaves.\n","    # ------------------------------------------------------------------\n","    smoothed_source_score = _smooth_scores_by_leaf_neighbors(\n","        raw_source_score,\n","        leaf_order=leaf_order,\n","        alpha=smooth_alpha,\n","        n_iters=smooth_iters,\n","    )\n","\n","    # ------------------------------------------------------------------\n","    # 5) Aggregate directional flow across the top split of the hierarchy\n","    #    Gives a coarse cluster-level directional map.\n","    # ------------------------------------------------------------------\n","    top_split_labels = _top_split_labels_from_linkage(Z, tickers)\n","    cluster_flow = _compute_cluster_flow(te_mat, top_split_labels)\n","\n","    return {\n","        \"te_matrix\": te_mat,\n","        \"symmetric_similarity\": symmetric_similarity,\n","        \"distance_matrix\": pd.DataFrame(dist_values, index=tickers, columns=tickers),\n","        \"linkage_matrix\": Z,\n","        \"leaf_order\": leaf_order,\n","        \"raw_source_score\": raw_source_score.sort_values(ascending=False),\n","        \"smoothed_source_score\": smoothed_source_score.sort_values(ascending=False),\n","        \"cluster_flow\": cluster_flow,\n","        \"top_split_labels\": top_split_labels,\n","        \"metadata\": {\n","            \"corr_method\": corr_method,\n","            \"linkage_method\": linkage_method,\n","            \"corr_shrinkage\": corr_shrinkage,\n","            \"min_obs\": min_obs,\n","            \"zero_negative_te\": zero_negative_te,\n","            \"symmetrize_for_tree\": symmetrize_for_tree,\n","            \"smooth_iters\": smooth_iters,\n","            \"smooth_alpha\": smooth_alpha,\n","        },\n","    }\n","\n","\n","def _compute_te_matrix(\n","    df: pd.DataFrame,\n","    calculate_transfer_entropy,\n","    te_kwargs: dict,\n","    min_obs: int,\n","    zero_negative_te: bool,\n",") -> pd.DataFrame:\n","    tickers = list(df.columns)\n","    n = len(tickers)\n","    te = pd.DataFrame(np.zeros((n, n)), index=tickers, columns=tickers, dtype=float)\n","\n","    for src in tickers:\n","        x = df[src]\n","        for dst in tickers:\n","            if src == dst:\n","                te.loc[src, dst] = 0.0\n","                continue\n","\n","            y = df[dst]\n","            xy = pd.concat([x, y], axis=1).dropna()\n","            if len(xy) < min_obs:\n","                te.loc[src, dst] = np.nan\n","                continue\n","\n","            val = calculate_transfer_entropy(\n","                xy.iloc[:, 0].values,\n","                xy.iloc[:, 1].values,\n","                **te_kwargs,\n","            )\n","\n","            val = float(val)\n","            if zero_negative_te:\n","                val = max(val, 0.0)\n","\n","            te.loc[src, dst] = val\n","\n","    return te.fillna(0.0)\n","\n","\n","def _smooth_scores_by_leaf_neighbors(\n","    scores: pd.Series,\n","    leaf_order: list[str],\n","    alpha: float = 0.5,\n","    n_iters: int = 2,\n",") -> pd.Series:\n","    \"\"\"\n","    Local smoothing along dendrogram leaf order.\n","    This is a lightweight tree-regularization proxy:\n","    nearby leaves in the hierarchy borrow strength from each other.\n","    \"\"\"\n","    alpha = float(np.clip(alpha, 0.0, 1.0))\n","    s = scores.reindex(leaf_order).astype(float).copy()\n","\n","    if len(s) <= 2 or alpha == 0 or n_iters <= 0:\n","        return scores.copy()\n","\n","    vals = s.values.copy()\n","    for _ in range(n_iters):\n","        new_vals = vals.copy()\n","        for i in range(len(vals)):\n","            nbrs = []\n","            if i - 1 >= 0:\n","                nbrs.append(vals[i - 1])\n","            if i + 1 < len(vals):\n","                nbrs.append(vals[i + 1])\n","\n","            if nbrs:\n","                local_avg = np.mean(nbrs)\n","                new_vals[i] = (1 - alpha) * vals[i] + alpha * local_avg\n","        vals = new_vals\n","\n","    out = pd.Series(vals, index=leaf_order)\n","    return out.reindex(scores.index)\n","\n","\n","def _top_split_labels_from_linkage(Z: np.ndarray, tickers: list[str]) -> pd.Series:\n","    \"\"\"\n","    Extract the top-level 2-way split from linkage.\n","    Returns labels 0/1 per ticker.\n","    \"\"\"\n","    n = len(tickers)\n","    if n == 2:\n","        return pd.Series([0, 1], index=tickers)\n","\n","    # Last merge joins two subtrees: left child and right child\n","    left = int(Z[-1, 0])\n","    right = int(Z[-1, 1])\n","\n","    left_members = _get_cluster_members(Z, left, n)\n","    right_members = _get_cluster_members(Z, right, n)\n","\n","    labels = pd.Series(index=tickers, dtype=int)\n","    labels.iloc[left_members] = 0\n","    labels.iloc[right_members] = 1\n","    return labels\n","\n","\n","def _get_cluster_members(Z: np.ndarray, node_id: int, n_leaves: int) -> list[int]:\n","    \"\"\"\n","    Recursively recover leaf indices beneath a linkage node.\n","    Leaf ids are [0, ..., n_leaves-1].\n","    Internal node ids are [n_leaves, ..., 2*n_leaves-2].\n","    \"\"\"\n","    if node_id < n_leaves:\n","        return [node_id]\n","\n","    row = node_id - n_leaves\n","    left = int(Z[row, 0])\n","    right = int(Z[row, 1])\n","    return _get_cluster_members(Z, left, n_leaves) + _get_cluster_members(Z, right, n_leaves)\n","\n","\n","def _compute_cluster_flow(te_mat: pd.DataFrame, labels: pd.Series) -> pd.DataFrame:\n","    \"\"\"\n","    Aggregate directional flow across the top-level split.\n","    \"\"\"\n","    clusters = sorted(labels.unique())\n","    out = pd.DataFrame(0.0, index=clusters, columns=clusters)\n","\n","    for a in clusters:\n","        members_a = labels.index[labels == a]\n","        for b in clusters:\n","            members_b = labels.index[labels == b]\n","            out.loc[a, b] = te_mat.loc[members_a, members_b].values.sum()\n","\n","    # Add net directional flow convenience columns\n","    out = out.copy()\n","    if len(clusters) == 2:\n","        a, b = clusters\n","        net_ab = out.loc[a, b] - out.loc[b, a]\n","        out.attrs[\"net_flow_0_to_1\"] = net_ab\n","\n","    return out"],"metadata":{"id":"xrI_wxpjprlF","executionInfo":{"status":"ok","timestamp":1773121054280,"user_tz":420,"elapsed":72,"user":{"displayName":"Klepto Mikey","userId":"16754173383394045540"}}},"execution_count":42,"outputs":[]},{"cell_type":"code","source":["result = build_hierarchical_te_field(\n","    returns_df=df_returns,\n","    calculate_transfer_entropy=calculate_transfer_entropy,\n","    te_kwargs={},\n","    corr_method=\"spearman\",\n","    linkage_method=\"average\",\n","    symmetrize_for_tree=\"corr\",\n","    smooth_iters=3,\n","    smooth_alpha=0.35,\n",")\n","\n","te_matrix = result[\"te_matrix\"]\n","leaders = result[\"smoothed_source_score\"]\n","cluster_flow = result[\"cluster_flow\"]\n","leaf_order = result[\"leaf_order\"]"],"metadata":{"id":"jHx-69UuDjvd","executionInfo":{"status":"ok","timestamp":1773121093273,"user_tz":420,"elapsed":37207,"user":{"displayName":"Klepto Mikey","userId":"16754173383394045540"}},"collapsed":true},"execution_count":43,"outputs":[]},{"cell_type":"code","source":["import numpy as np\n","import pandas as pd\n","import networkx as nx\n","\n","import numpy as np\n","import pandas as pd\n","import networkx as nx\n","\n","\n","def build_te_lag_arborescence(\n","    returns_df: pd.DataFrame,\n","    calculate_te_func,\n","    max_lag: int = 10,\n","    min_obs: int = 50,\n","    edge_threshold: float | None = None,\n","    root_mode: str = \"auto\",\n","):\n","    \"\"\"\n","    Build a maximum spanning arborescence from TE(src -> dst),\n","    while also storing the optimal lag for each retained edge.\n","    \"\"\"\n","    te_matrix, lag_matrix = compute_te_and_lag_matrices(\n","        df=returns_df,\n","        calculate_te_func=calculate_te_func,\n","        max_lag=max_lag,\n","        min_obs=min_obs,\n","    )\n","\n","    outflow = te_matrix.sum(axis=1)\n","    inflow = te_matrix.sum(axis=0)\n","    source_score = (outflow - inflow).sort_values(ascending=False)\n","\n","    tickers = list(te_matrix.index)\n","\n","    if root_mode == \"auto\":\n","        root = source_score.index[0]\n","    else:\n","        if root_mode not in tickers:\n","            raise ValueError(f\"Invalid root: {root_mode}\")\n","        root = root_mode\n","\n","    threshold = 0.0 if edge_threshold is None else float(edge_threshold)\n","\n","    G = nx.DiGraph()\n","    G.add_nodes_from(tickers)\n","\n","    for src in tickers:\n","        for dst in tickers:\n","            if src == dst:\n","                continue\n","\n","            w = float(te_matrix.loc[src, dst])\n","            lag = lag_matrix.loc[src, dst]\n","\n","            if np.isfinite(w) and w > threshold:\n","                G.add_edge(src, dst, weight=w, lag=None if pd.isna(lag) else int(lag))\n","\n","    eps = 1e-12\n","    for node in tickers:\n","        if node != root and not G.has_edge(root, node):\n","            G.add_edge(root, node, weight=eps, lag=None)\n","\n","    super_root = \"__SUPER_ROOT__\"\n","    H = G.copy()\n","    H.add_node(super_root)\n","\n","    big = max([d[\"weight\"] for _, _, d in H.edges(data=True)] + [1.0]) * 1_000_000.0\n","    H.add_edge(super_root, root, weight=big, lag=None)\n","\n","    arb_full = nx.maximum_spanning_arborescence(H, attr=\"weight\")\n","\n","    arb = nx.DiGraph()\n","    arb.add_nodes_from(tickers)\n","\n","    for u, v, d in arb_full.edges(data=True):\n","        if u == super_root or v == super_root:\n","            continue\n","        arb.add_edge(u, v, weight=d[\"weight\"], lag=d.get(\"lag\"))\n","\n","    topo_order = list(nx.topological_sort(arb))\n","    levels = _compute_levels_from_root(arb, root)\n","\n","    edges_df = pd.DataFrame(\n","        [\n","            {\n","                \"parent\": u,\n","                \"child\": v,\n","                \"te\": d[\"weight\"],\n","                \"lag\": d.get(\"lag\"),\n","                \"parent_level\": levels.get(u),\n","                \"child_level\": levels.get(v),\n","            }\n","            for u, v, d in arb.edges(data=True)\n","        ]\n","    ).sort_values([\"parent_level\", \"te\"], ascending=[True, False]).reset_index(drop=True)\n","\n","    return {\n","        \"te_matrix\": te_matrix,\n","        \"lag_matrix\": lag_matrix,\n","        \"source_score\": source_score,\n","        \"root\": root,\n","        \"graph\": arb,\n","        \"edges\": edges_df,\n","        \"topological_order\": topo_order,\n","        \"levels\": pd.Series(levels).sort_values(),\n","    }\n","\n","\n","def _compute_levels_from_root(G: nx.DiGraph, root: str) -> dict[str, int]:\n","    levels = {root: 0}\n","    queue = [root]\n","\n","    while queue:\n","        u = queue.pop(0)\n","        for v in G.successors(u):\n","            if v not in levels:\n","                levels[v] = levels[u] + 1\n","                queue.append(v)\n","\n","    return levels\n","\n","def _compute_te_matrix(\n","    df: pd.DataFrame,\n","    calculate_transfer_entropy,\n","    te_kwargs: dict,\n","    min_obs: int,\n","    zero_negative_te: bool,\n",") -> pd.DataFrame:\n","    tickers = list(df.columns)\n","    te = pd.DataFrame(0.0, index=tickers, columns=tickers, dtype=float)\n","\n","    for src in tickers:\n","        x = df[src]\n","        for dst in tickers:\n","            if src == dst:\n","                continue\n","\n","            y = df[dst]\n","            xy = pd.concat([x, y], axis=1).dropna()\n","\n","            if len(xy) < min_obs:\n","                te.loc[src, dst] = 0.0\n","                continue\n","\n","            val = float(\n","                calculate_transfer_entropy(\n","                    xy.iloc[:, 0].values,\n","                    xy.iloc[:, 1].values,\n","                    **te_kwargs,\n","                )\n","            )\n","\n","            if zero_negative_te:\n","                val = max(val, 0.0)\n","\n","            te.loc[src, dst] = val\n","\n","    return te\n","\n","\n","import numpy as np\n","import pandas as pd\n","\n","\n","def compute_te_and_lag_matrices(\n","    df: pd.DataFrame,\n","    calculate_te_func,\n","    max_lag: int = 10,\n","    min_obs: int = 50,\n","):\n","    \"\"\"\n","    Builds:\n","      te_matrix[src, dst]  = TE(src -> dst)\n","      lag_matrix[src, dst] = optimal lag for src -> dst\n","    \"\"\"\n","    df = df.copy().sort_index()\n","    df = df.replace([np.inf, -np.inf], np.nan)\n","\n","    tickers = [c for c in df.columns if df[c].notna().sum() >= min_obs]\n","    df = df[tickers]\n","\n","    te_matrix = pd.DataFrame(0.0, index=tickers, columns=tickers, dtype=float)\n","    lag_matrix = pd.DataFrame(np.nan, index=tickers, columns=tickers, dtype=float)\n","\n","    for src in tickers:\n","        for dst in tickers:\n","            if src == dst:\n","                te_matrix.loc[src, dst] = 0.0\n","                lag_matrix.loc[src, dst] = 0\n","                continue\n","\n","            pair = df[[src, dst]].dropna()\n","            if len(pair) < min_obs:\n","                continue\n","\n","            # calculate_te_func(X, Y) returns TE(Y -> X)\n","            # so to get TE(src -> dst), pass X=dst, Y=src\n","            te, lag = calculate_te_func(\n","                pair[dst].values,\n","                pair[src].values,\n","                max_lag=max_lag,\n","                return_lag=True,\n","            )\n","\n","            te_matrix.loc[src, dst] = te\n","            lag_matrix.loc[src, dst] = lag\n","\n","    lag_matrix = lag_matrix.astype(\"Int64\")\n","    return te_matrix, lag_matrix\n","\n","def _compute_levels_fro