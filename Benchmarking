{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"mount_file_id":"1a8BnHzSkqWCHLFx1qL1A1Q8YXwDrBpmN","authorship_tag":"ABX9TyMxlcX0VidT2OeT//2O1Vwl"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":1,"metadata":{"id":"5qwwnzwGlQ2L","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1772092001195,"user_tz":480,"elapsed":73,"user":{"displayName":"Klepto Mikey","userId":"16754173383394045540"}},"outputId":"a120d132-866c-482f-9b87-9bd2d7652332"},"outputs":[{"output_type":"stream","name":"stdout","text":["Current working directory is: /content/drive/MyDrive/CopulaEntropy\n"]}],"source":["import os\n","# Change the current working directory to your Google Drive folder\n","google_drive_path = \"/content/drive/MyDrive/CopulaEntropy\"\n","os.chdir(google_drive_path)\n","\n","# Youorig_pre_df, post_df = process_phh_zip(\"phh_hands_backup.zip\", True) can now call your function using just the filename\n","\n","# --- To verify (optional) ---\n","# You can print the current working directory to confirm\n","print(f\"Current working directory is: {os.getcwd()}\")"]},{"cell_type":"code","source":["import numpy as np\n","from CopulaEntropy import CopulaEntropyEstimator"],"metadata":{"id":"gSj8GZ9w0aKF","executionInfo":{"status":"ok","timestamp":1772092003663,"user_tz":480,"elapsed":2465,"user":{"displayName":"Klepto Mikey","userId":"16754173383394045540"}}},"execution_count":2,"outputs":[]},{"cell_type":"code","source":["import numpy as np\n","import pandas as pd\n","\n","# --- Ground-truth MI cases (1d -> 1d) with closed-form MI (in nats) ---\n","\n","def gen_bivariate_gaussian(n, rho, seed=0):\n","    \"\"\"\n","    X,Y ~ N(0, Σ), Σ = [[1, rho],[rho,1]]\n","    Ground-truth: I(X;Y) = -0.5 * log(1 - rho^2)  (nats)\n","    \"\"\"\n","    rng = np.random.default_rng(seed)\n","    # Cholesky of [[1, rho],[rho,1]] is [[1, 0],[rho, sqrt(1-rho^2)]]\n","    x = rng.standard_normal(n)\n","    y = rho * x + np.sqrt(1.0 - rho * rho) * rng.standard_normal(n)\n","\n","    mi_true = -0.5 * np.log(1.0 - rho * rho)\n","    return x.reshape(-1, 1), y.reshape(-1, 1), mi_true\n","\n","\n","def gen_awgn_channel(n, noise_std, seed=0):\n","    \"\"\"\n","    AWGN channel: X ~ N(0,1), Y = X + N(0, noise_std^2)\n","    Ground-truth: I(X;Y) = 0.5 * log(1 + 1/noise_std^2)  (nats)\n","    \"\"\"\n","    rng = np.random.default_rng(seed)\n","    x = rng.standard_normal(n)\n","    y = x + noise_std * rng.standard_normal(n)\n","\n","    mi_true = 0.5 * np.log(1.0 + 1.0 / (noise_std * noise_std))\n","    return x.reshape(-1, 1), y.reshape(-1, 1), mi_true\n","\n","\n","# --- sklearn estimator wrapper (kNN MI, returns nats) ---\n","def estimate_mi_sklearn(X, Y, *, n_neighbors=3, random_state=0):\n","    \"\"\"\n","    X: (n,1) feature matrix\n","    Y: (n,1) or (n,) target\n","    Returns: scalar MI estimate in nats\n","    \"\"\"\n","    from sklearn.feature_selection import mutual_info_regression\n","\n","    X = np.asarray(X)\n","    Y = np.asarray(Y).reshape(-1)\n","\n","    # mutual_info_regression returns an array, one MI per feature\n","    mi = mutual_info_regression(\n","        X, Y,\n","        n_neighbors=n_neighbors,\n","        random_state=random_state\n","    )[0]\n","    return float(mi)\n","\n","\n","# --- Your estimator placeholder ---\n","# You said you already have these; keep signatures consistent.\n","# def estimate_mi_from_ce(X, Y, **kwargs): ...\n","\n","import numpy as np\n","from scipy.stats import norm\n","\n","\n","def gen_gaussian_copula(n, rho, fx, fy, seed=0):\n","    rng = np.random.default_rng(seed)\n","\n","    z1 = rng.standard_normal(n)\n","    z2 = rho * z1 + np.sqrt(1 - rho**2) * rng.standard_normal(n)\n","\n","    u = norm.cdf(z1)\n","    v = norm.cdf(z2)\n","\n","    x = fx(u)\n","    y = fy(v)\n","\n","    # MI depends only on copula\n","    mi_true = -0.5 * np.log(1 - rho**2)\n","\n","    return x.reshape(-1, 1), y.reshape(-1, 1), mi_true\n","\n","from scipy.stats import norm, expon, lognorm, t\n","\n","def gen_gaussian_copula(\n","    n,\n","    rho,\n","    fx=\"exp\",\n","    fy=\"lognormal\",\n","    seed=0,\n","):\n","    \"\"\"\n","    Non-Gaussian marginals, Gaussian copula.\n","\n","    MI = -0.5 * log(1 - rho^2)\n","    \"\"\"\n","\n","    rng = np.random.default_rng(seed)\n","\n","    # Step 1: correlated Gaussian\n","    u = rng.standard_normal(n)\n","    v = rho * u + np.sqrt(1 - rho**2) * rng.standard_normal(n)\n","\n","    # Step 2: map to uniforms\n","    U = norm.cdf(u)\n","    V = norm.cdf(v)\n","\n","    # Step 3: choose marginals\n","    def transform(z, kind):\n","        if kind == \"exp\":\n","            return expon.ppf(z)\n","        if kind == \"lognormal\":\n","            return lognorm.ppf(z, s=0.8)\n","        if kind == \"t\":\n","            return t.ppf(z, df=3)\n","        raise ValueError(kind)\n","\n","    x = transform(U, fx)\n","    y = transform(V, fy)\n","\n","    mi_true = -0.5 * np.log(1 - rho**2)\n","\n","    return x[:, None], y[:, None], mi_true\n","\n","from scipy.special import logsumexp\n","\n","def gen_binary_gaussian_channel(n, sigma, seed=0):\n","    \"\"\"\n","    X ∈ {-1,+1}, Y = X + N(0,σ²)\n","\n","    MI computed numerically (high precision)\n","    \"\"\"\n","\n","    rng = np.random.default_rng(seed)\n","\n","    x = rng.choice([-1.0, 1.0], size=n)\n","    y = x + sigma * rng.standard_normal(n)\n","\n","    # Ground truth via Monte Carlo\n","    def mi_mc(ns=2_000_000):\n","        x0 = rng.choice([-1.0, 1.0], size=ns)\n","        y0 = x0 + sigma * rng.standard_normal(ns)\n","\n","        logp_y_x = -0.5*((y0-x0)/sigma)**2 - np.log(np.sqrt(2*np.pi)*sigma)\n","\n","        logp_y = logsumexp([\n","            -0.5*((y0-1)/sigma)**2,\n","            -0.5*((y0+1)/sigma)**2\n","        ], axis=0) - np.log(2*np.sqrt(2*np.pi)*sigma)\n","\n","        return np.mean(logp_y_x - logp_y)\n","\n","    mi_true = mi_mc()\n","\n","    return x[:,None], y[:,None], mi_true\n","\n","from scipy.stats import gaussian_kde\n","\n","def gen_nonlinear_noise(n, sigma, seed=0):\n","    \"\"\"\n","    Y = sin(3X) + noise\n","\n","    MI estimated at high resolution\n","    \"\"\"\n","\n","    rng = np.random.default_rng(seed)\n","\n","    x = rng.uniform(-1, 1, size=n)\n","    y = np.sin(3*x) + sigma * rng.standard_normal(n)\n","\n","    # High-quality MI via KDE\n","    def mi_kde(ns=200_000):\n","\n","        x0 = rng.uniform(-1,1,ns)\n","        y0 = np.sin(3*x0) + sigma*rng.standard_normal(ns)\n","\n","        xy = np.vstack([x0,y0])\n","        kde_xy = gaussian_kde(xy)\n","\n","        kde_x = gaussian_kde(x0)\n","        kde_y = gaussian_kde(y0)\n","\n","        logp_xy = np.log(kde_xy(xy))\n","        logp_x  = np.log(kde_x(x0))\n","        logp_y  = np.log(kde_y(y0))\n","\n","        return np.mean(logp_xy - logp_x - logp_y)\n","\n","    mi_true = mi_kde()\n","\n","    return x[:,None], y[:,None], mi_true\n","\n","\n","# Wrapper with correct signature for benchmark\n","def gen_gaussian_copula_wrapped(n, seed, rho, fx, fy):\n","    return gen_gaussian_copula(n, rho, fx, fy, seed)\n","\n","\n","import numpy as np\n","from scipy.stats import t\n","from scipy.special import gammaln\n","\n","def gen_t_copula(n, rho, nu, seed=0):\n","    rng = np.random.default_rng(seed)\n","\n","    # Correlated normals\n","    z1 = rng.standard_normal(n)\n","    z2 = rho*z1 + np.sqrt(1-rho**2)*rng.standard_normal(n)\n","\n","    # Shared chi-square scaling\n","    w = rng.chisquare(nu, size=n)\n","\n","    x = z1 / np.sqrt(w/nu)\n","    y = z2 / np.sqrt(w/nu)\n","\n","    # --- analytic MI ---\n","    term1 = (\n","        2*gammaln(nu/2)\n","        - 2*gammaln((nu+1)/2)\n","        + gammaln((nu+2)/2)\n","        - gammaln(nu/2)\n","    )\n","\n","    mi_true = term1 - 0.5*np.log(1-rho**2)\n","\n","    return x.reshape(-1,1), y.reshape(-1,1), mi_true\n","\n","import numpy as np\n","from scipy.stats import norm\n","\n","def gen_fgm_copula(n, theta, fx=norm.ppf, fy=norm.ppf, seed=0):\n","    \"\"\"\n","    Farlie-Gumbel-Morgenstern (FGM) copula.\n","    theta: float in [-1, 1]. Captures weak/smooth dependence.\n","    \"\"\"\n","    rng = np.random.default_rng(seed)\n","    u = rng.uniform(0, 1, n)\n","    w = rng.uniform(0, 1, n)\n","\n","    # Invert conditional CDF C(v|u) = w using the quadratic formula\n","    A = -theta * (1 - 2 * u)\n","    B = 1 - A\n","    C_term = -w\n","\n","    # Avoid division by zero when A approaches 0\n","    v = np.where(\n","        np.abs(A) < 1e-9,\n","        w,\n","        (-B + np.sqrt(B**2 - 4 * A * C_term)) / (2 * A)\n","    )\n","\n","    # Calculate exact analytical MI using the infinite series\n","    # MI = sum_{m=1}^inf theta^(2m) / (2m * (2m-1) * (2m+1)^2)\n","    m = np.arange(1, 100) # 100 terms is more than enough for machine precision\n","    mi_true = np.sum((theta**(2*m)) / (2*m * (2*m - 1) * (2*m + 1)**2))\n","\n","    x = fx(u)\n","    y = fy(v)\n","\n","    return x.reshape(-1, 1), y.reshape(-1, 1), float(mi_true)\n","\n","\n","def gen_checkerboard_copula(n, P, fx=norm.ppf, fy=norm.ppf, seed=0):\n","    \"\"\"\n","    Grid / Checkerboard copula for arbitrary discrete dependence.\n","    P: An M x M matrix where rows and cols sum to 1/M.\n","    \"\"\"\n","    P = np.asarray(P)\n","    M = P.shape[0]\n","\n","    # Validate P matrix marginals\n","    assert np.allclose(P.sum(axis=0), 1/M), \"Columns must sum to 1/M\"\n","    assert np.allclose(P.sum(axis=1), 1/M), \"Rows must sum to 1/M\"\n","\n","    rng = np.random.default_rng(seed)\n","\n","    # 1. Sample grid cell from the flattened probability distribution\n","    P_flat = P.flatten()\n","    cell_indices = rng.choice(M*M, size=n, p=P_flat)\n","\n","    row_idx = cell_indices // M\n","    col_idx = cell_indices % M\n","\n","    # 2. Sample uniformly within the chosen cells\n","    u = (row_idx + rng.uniform(0, 1, n)) / M\n","    v = (col_idx + rng.uniform(0, 1, n)) / M\n","\n","    # Calculate exact MI: sum(P_ij * ln(M^2 * P_ij))\n","    P_nz = P[P > 0]\n","    mi_true = np.sum(P_nz * np.log(M**2 * P_nz))\n","\n","    x = fx(u)\n","    y = fy(v)\n","\n","    return x.reshape(-1, 1), y.reshape(-1, 1), float(mi_true)\n","\n","\n","import numpy as np\n","from scipy.stats import norm, expon, lognorm, t as student_t\n","\n","def _transform_ppf(U, kind):\n","    if callable(kind):\n","        return kind(U)\n","    kind = str(kind).lower()\n","    if kind == \"exp\":\n","        return expon.ppf(U)\n","    if kind == \"lognormal\":\n","        return lognorm.ppf(U, s=0.8)\n","    if kind == \"t\":\n","        return student_t.ppf(U, df=3)\n","    if kind == \"gauss\":\n","        return norm.ppf(U)\n","    raise ValueError(kind)\n","\n","from scipy.stats import norm\n","\n","def gen_gaussian_copula_xd_y1(n, R, fxs=None, fy=norm.ppf, seed=0):\n","    \"\"\"\n","    Gaussian copula with arbitrary marginals.\n","    R: (d+1, d+1) correlation matrix for [X1..Xd, Y]\n","    fxs: list of length d (callables or strings understood by _transform_ppf)\n","    fy: callable or string\n","    \"\"\"\n","    rng = np.random.default_rng(seed)\n","    R = np.asarray(R, float)\n","    d1 = R.shape[0]\n","    assert R.shape == (d1, d1)\n","    d = d1 - 1\n","\n","    # sample correlated normals\n","    L = np.linalg.cholesky(R)\n","    Z = rng.standard_normal((n, d1)) @ L.T\n","    U = norm.cdf(Z)\n","\n","    if fxs is None:\n","        fxs = [\"gauss\"] * d\n","    assert len(fxs) == d\n","\n","    X_cols = [_transform_ppf(U[:, j], fxs[j]) for j in range(d)]\n","    X = np.column_stack(X_cols)\n","    Y = _transform_ppf(U[:, d], fy)[:, None]\n","\n","    # analytic MI\n","    Rxx = R[:d, :d]\n","    _, logdet_Rxx = np.linalg.slogdet(Rxx)\n","    _, logdet_R   = np.linalg.slogdet(R)\n","    mi_true = 0.5 * (logdet_Rxx - logdet_R)\n","\n","    return X, Y, float(mi_true)\n","\n","def gen_linear_gaussian_dto1(n, a, noise_std=1.0, seed=0):\n","    \"\"\"\n","    X ~ N(0, I_d), Y = a^T X + N(0, noise_std^2)\n","    MI = 0.5 * log(1 + ||a||^2 / noise_std^2)\n","    \"\"\"\n","    rng = np.random.default_rng(seed)\n","    a = np.asarray(a, float)\n","    d = a.size\n","    X = rng.standard_normal((n, d))\n","    y = X @ a + noise_std * rng.standard_normal(n)\n","\n","    snr = float(np.dot(a, a) / (noise_std * noise_std))\n","    mi_true = 0.5 * np.log(1.0 + snr)\n","    return X, y[:, None], float(mi_true)\n","\n","\n","import numpy as np\n","from scipy.stats import norm\n","\n","def gen_3d_gaussian_copula(n, Sigma, fx=norm.ppf, fy=norm.ppf, seed=0):\n","    \"\"\"\n","    3D Gaussian copula. X is 2D, Y is 1D.\n","    Sigma: A 3x3 correlation matrix. Indices 0,1 are X. Index 2 is Y.\n","    \"\"\"\n","    Sigma = np.asarray(Sigma)\n","    assert Sigma.shape == (3, 3), \"Sigma must be 3x3\"\n","    assert np.allclose(np.diag(Sigma), 1.0), \"Diagonal of Sigma must be 1\"\n","\n","    rng = np.random.default_rng(seed)\n","\n","    # Sample from 3D Multivariate Normal\n","    mean = np.zeros(3)\n","    Z = rng.multivariate_normal(mean, Sigma, size=n)\n","\n","    # Map to uniform via CDF\n","    U = norm.cdf(Z)\n","\n","    # Map to target marginals\n","    # Applying fx to both dimensions of X, and fy to Y\n","    X_mat = np.column_stack([fx(U[:, 0]), fx(U[:, 1])])\n","    Y_mat = fy(U[:, 2]).reshape(-1, 1)\n","\n","    # Analytical MI: 0.5 * log(|Sigma_X|) - 0.5 * log(|Sigma|)\n","    Sigma_X = Sigma[:2, :2]\n","    _, logdet_X = np.linalg.slogdet(Sigma_X)\n","    _, logdet_full = np.linalg.slogdet(Sigma)\n","\n","    mi_true = 0.5 * logdet_X - 0.5 * logdet_full\n","\n","    return X_mat, Y_mat, float(mi_true)\n","\n","\n","def gen_3d_checkerboard_copula(n, P, fx=norm.ppf, fy=norm.ppf, seed=0):\n","    \"\"\"\n","    3D Checkerboard copula.\n","    P: An M x M x M probability tensor where 1D marginals sum to 1/M.\n","    \"\"\"\n","    P = np.asarray(P)\n","    M = P.shape[0]\n","    assert P.shape == (M, M, M), \"P must be a cube (M, M, M)\"\n","\n","    # Validate uniform 1D marginals\n","    assert np.allclose(P.sum(axis=(1, 2)), 1/M), \"Dim 0 marginal must be 1/M\"\n","    assert np.allclose(P.sum(axis=(0, 2)), 1/M), \"Dim 1 marginal must be 1/M\"\n","    assert np.allclose(P.sum(axis=(0, 1)), 1/M), \"Dim 2 marginal must be 1/M\"\n","\n","    rng = np.random.default_rng(seed)\n","\n","    # 1. Sample 3D grid cells\n","    P_flat = P.flatten()\n","    cell_indices = rng.choice(M**3, size=n, p=P_flat)\n","\n","    # Decode flat index back to 3D indices (i, j, k)\n","    idx_0 = cell_indices // (M * M)\n","    idx_1 = (cell_indices // M) % M\n","    idx_2 = cell_indices % M\n","\n","    # 2. Sample uniformly within the chosen 3D cells\n","    u0 = (idx_0 + rng.uniform(0, 1, n)) / M\n","    u1 = (idx_1 + rng.uniform(0, 1, n)) / M\n","    v  = (idx_2 + rng.uniform(0, 1, n)) / M\n","\n","    # Map to marginals\n","    X_mat = np.column_stack([fx(u0), fx(u1)])\n","    Y_mat = fy(v).reshape(-1, 1)\n","\n","    # 3. Calculate Exact MI\n","    P_X = P.sum(axis=2) # 2D marginal for X (shape M x M)\n","    P_Y = 1.0 / M       # 1D marginal for Y is known uniform\n","\n","    mi_true = 0.0\n","    for i in range(M):\n","        for j in range(M):\n","            for k in range(M):\n","                p_ijk = P[i, j, k]\n","                if p_ijk > 0:\n","                    # I(X;Y) = sum P(x,y) log ( P(x,y) / (P(x)P(y)) )\n","                    mi_true += p_ijk * np.log(p_ijk / (P_X[i, j] * P_Y))\n","\n","    return X_mat, Y_mat, float(mi_true)\n","\n","\n","import numpy as np\n","\n","def get_3d_diagonal_tensor(M=4):\n","    P = np.zeros((M, M, M))\n","\n","    # Put mass along i=j=k diagonal\n","    for i in range(M):\n","        P[i, i, i] = 1.0\n","\n","    P /= P.sum()  # normalize to 1\n","\n","    # This construction gives uniform 1D marginals automatically\n","    return P\n","\n","\n","# --- Helper to create a highly nonlinear X-shape probability matrix ---\n","def get_x_shape_matrix(M=5):\n","    P = np.zeros((M, M))\n","    for i in range(M):\n","        P[i, i] += 1\n","        P[i, M - 1 - i] += 1\n","    P = P / np.sum(P) # Normalizes to 1/M marginals by design\n","    return P\n","\n","def benchmark_mi_wide(\n","    estimators,                 # dict: name -> callable(X, Y)\n","    cases,\n","    n_list=(200, 500, 2000),\n","    repeats=20,\n","    base_seed=123,\n","    unit=\"nats\",\n","    est_kwargs={}\n","):\n","    \"\"\"\n","    Returns:\n","        df_runs   : per-run long dataframe\n","        df_wide   : wide summary with one column per estimator\n","    \"\"\"\n","    import numpy as np\n","    import pandas as pd\n","\n","    rows = []\n","    ln2 = np.log(2.0)\n","\n","    # -------------------------------\n","    # Collect per-run data (same as before)\n","    # -------------------------------\n","    for case in cases:\n","        case_name = case[\"name\"]\n","        gen = case[\"gen\"]\n","        params = case.get(\"params\", {})\n","\n","        for n in n_list:\n","            for r in range(repeats):\n","\n","                seed = (\n","                    base_seed\n","                    + 10_000 * hash(case_name) % 1_000_000\n","                    + 1_000 * n\n","                    + r\n","                )\n","\n","                X, Y, mi_true = gen(n=n, seed=seed, **params)\n","\n","                print(X.shape,Y.shape)\n","\n","                mi_true_rep = mi_true / ln2 if unit == \"bits\" else mi_true\n","\n","                for est_name, est_fn in estimators.items():\n","\n","                    mi_hat = est_fn(X, Y)\n","                    mi_hat_rep = mi_hat / ln2 if unit == \"bits\" else mi_hat\n","\n","                    rows.append({\n","                        \"case\": case_name,\n","                        \"n\": n,\n","                        \"repeat\": r,\n","                        \"estimator\": est_name,\n","                        \"mi_true\": mi_true_rep,\n","                        \"mi_hat\": mi_hat_rep,\n","                        \"error\": mi_hat_rep - mi_true_rep,\n","                        \"abs_error\": abs(mi_hat_rep - mi_true_rep),\n","                    })\n","\n","    df_runs = pd.DataFrame(rows)\n","\n","    # -------------------------------\n","    # Aggregate (still long)\n","    # -------------------------------\n","    df_long = (\n","        df_runs\n","        .groupby([\"case\", \"n\", \"estimator\"])\n","        .agg(\n","            mi_true_mean=(\"mi_true\", \"mean\"),\n","            mi_hat_mean=(\"mi_hat\", \"mean\"),\n","            mi_hat_std=(\"mi_hat\", \"std\"),\n","            bias=(\"error\", \"mean\"),\n","            mae=(\"abs_error\", \"mean\"),\n","            rmse=(\"error\", lambda x: np.sqrt(np.mean(x**2))),\n","        )\n","        .reset_index()\n","    )\n","\n","    # -------------------------------\n","    # Pivot to wide format\n","    # -------------------------------\n","    df_wide = (\n","        df_long\n","        .pivot(index=[\"case\", \"n\"],\n","               columns=\"estimator\")\n","    )\n","\n","    # Flatten multi-index columns\n","    df_wide.columns = [\n","        f\"{metric}_{est}\"\n","        for metric, est in df_wide.columns\n","    ]\n","\n","    df_wide = df_wide.reset_index().sort_values([\"case\", \"n\"])\n","\n","    return df_runs, df_wide\n","\n","import numpy as np\n","\n","def make_block_correlation(d_x, rho_x=0.3, rho_y=0.6):\n","    \"\"\"\n","    Creates correlation matrix for (X1..Xd_x, Y)\n","    \"\"\"\n","    d = d_x + 1\n","    R = np.eye(d)\n","\n","    # X-X block\n","    for i in range(d_x):\n","        for j in range(d_x):\n","            if i != j:\n","                R[i, j] = rho_x\n","\n","    # X-Y correlations\n","    for i in range(d_x):\n","        R[i, d_x] = rho_y\n","        R[d_x, i] = rho_y\n","\n","    return R\n","\n","\n","# --- Example usage ---\n","if __name__ == \"__main__\":\n","    # Plug in your estimator here:\n","    # from your_module import estimate_mi_from_ce\n","\n","    est_kwargs={'degree': 3,\n","          'max_num_mc': 10000,\n","          'max_num_mc_adapt': 0,\n","          'feature_mode': 'hybrid_b',\n","          'alpha_reg': 0,\n","          'random_state': 0}\n","\n","\n","    estimators = {\n","        \"sklearn_knn\": lambda X, Y: estimate_mi_sklearn(X, Y, n_neighbors=5, random_state=0),\n","        \"from_ce\": lambda X,Y: estimate_mi_from_ce(X,Y,**est_kwargs),\n","    }\n","\n","    cases = [\n","\n","              # Gaussian baseline\n","             {\"name\":\"gauss_05\",\n","              \"gen\": gen_bivariate_gaussian,\n","              \"params\":{\"rho\":0.5}},\n","\n","              # Copula\n","              {\"name\":\"copula_exp_t\",\n","              \"gen\": gen_gaussian_copula,\n","              \"params\":{\"rho\":0.7,\"fx\":\"exp\",\"fy\":\"t\"}},\n","\n","              # Binary channel\n","              {\"name\":\"bsc_gauss\",\n","              \"gen\": gen_binary_gaussian_channel,\n","              \"params\":{\"sigma\":0.7}},\n","\n","              {\"name\": \"t_rho_0.5_nu_3\", \"gen\": gen_t_copula, \"params\": {\"rho\": 0.5, \"nu\": 3}},\n","              {\"name\": \"t_rho_0.5_nu_10\", \"gen\": gen_t_copula, \"params\": {\"rho\": 0.5, \"nu\": 10}},\n","\n","              {\"name\": \"fgm_theta_1\",\n","              \"gen\": gen_fgm_copula,\n","              \"params\": {\"theta\": 1.0, \"fx\": norm.ppf, \"fy\": norm.ppf}},\n","\n","              # Checkerboard Copula (Highly nonlinear \"X-Shape\" dependence)\n","              {\"name\": \"checkerboard_x_shape\",\n","              \"gen\": gen_checkerboard_copula,\n","              \"params\": {\"P\": get_x_shape_matrix(M=5), \"fx\": norm.ppf, \"fy\": norm.ppf}},\n","\n","              {\"name\": \"checkerboard_x_shape\",\n","              \"gen\": gen_checkerboard_copula,\n","              \"params\": {\"P\": get_x_shape_matrix(M=9), \"fx\": norm.ppf, \"fy\": norm.ppf}},\n","\n","\n","              # Nonlinear\n","              #{\"name\":\"nonlinear\",\n","              #\"gen\": gen_nonlinear_noise,\n","              #\"params\":{\"sigma\":0.3}},\n","          ]\n","\n","\n","    from scipy.stats import norm\n","\n","    Sigma_3d = np.array([\n","                [1.0, 0.3, 0.6],\n","                [0.3, 1.0, 0.4],\n","                [0.6, 0.4, 1.0]\n","                  ])\n","\n","    cases_2d = [\n","\n","        {\n","            \"name\": \"lin_gauss_2to1\",\n","            \"gen\": gen_linear_gaussian_dto1,\n","            \"params\": {\"a\": (1.0, 0.5), \"noise_std\": 1.0},\n","        },\n","         {\"name\": \"gauss_3d_mixed\",\n","          \"gen\": gen_3d_gaussian_copula,\n","          \"params\": {\"Sigma\": Sigma_3d, \"fx\": norm.ppf, \"fy\": norm.ppf}},\n","\n","                {\n","                  \"name\": \"checkerboard3d_M4\",\n","                  \"gen\": gen_3d_checkerboard_copula,\n","                  \"params\": {\n","                      \"P\": get_3d_diagonal_tensor(M=4),\n","                      \"fx\": norm.ppf,\n","                      \"fy\": norm.ppf,\n","                  },\n","              },\n","    ]\n","\n","    R_6x6 = make_block_correlation(d_x=5, rho_x=0.3, rho_y=0.6)\n","\n","    cases_nd=[\n","         {\"name\": \"lin_gauss_5to1\",\n","        \"gen\": gen_linear_gaussian_dto1,\n","        \"params\": {\"a\": (1, 0.5, -0.2, 0.0, 0.1), \"noise_std\": 1.0}},\n","         {\"name\": \"gauss_copula_5d\",\n","          \"gen\": gen_gaussian_copula_xd_y1,\n","          \"params\": {\"R\": R_6x6, \"fxs\": [\"exp\",\"lognormal\",\"t\",\"gauss\",\"gauss\"], \"fy\": \"t\"}}\n","\n","    ]\n","\n","    # Set unit=\"nats\" to match sklearn outputs directly (recommended).\n","    df_runs, df_summary = benchmark_mi_wide(\n","        estimators=estimators,\n","        cases=cases,\n","        n_list=(1000,2000,500,5000,8000,200),\n","        repeats=1,\n","        base_seed=2026